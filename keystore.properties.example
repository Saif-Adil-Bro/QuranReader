# keystore.properties template
# Rename this file to keystore.properties and fill in your details.
# This file is excluded from version control (.gitignore) to keep your passwords secure.

# The name of your keystore file. If you put it in the project root directory, just write the filename.
storeFile=my-release-key.jks

# The password you entered under "Enter keystore password:"
storePassword=your_keystore_password_here

# The key alias you used (e.g. -alias my-key-alias)
keyAlias=my-key-alias

# The password for the key (usually same as storePassword, or custom if set)
keyPassword=your_key_password_here
