# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# QURAN_FOUNDATION_CLIENT_ID: Required for Quran Foundation API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
QURAN_FOUNDATION_CLIENT_ID=your_client_id_placeholder

# QURAN_FOUNDATION_CLIENT_SECRET: Required for Quran Foundation API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
QURAN_FOUNDATION_CLIENT_SECRET=your_client_secret_placeholder
